{
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6[1m]",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6[1m]",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(curl*)",
      "Bash(gh issue view*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git pull*)",
      "Bash(git show*)",
      "Bash(git status*)",
      "Bash(just*)",
      "Bash(make*)",
      "Bash(nix build*)",
      "Bash(nix flake*)",
      "WebFetch",
      "mcp__plugin_slack_slack__slack_read_canvas",
      "mcp__plugin_slack_slack__slack_read_channel",
      "mcp__plugin_slack_slack__slack_read_thread",
      "mcp__plugin_slack_slack__slack_read_user_profile",
      "mcp__plugin_slack_slack__slack_search_channels",
      "mcp__plugin_slack_slack__slack_search_public",
      "mcp__plugin_slack_slack__slack_search_public_and_private",
      "mcp__plugin_slack_slack__slack_search_users"
    ],
    "deny": [
      "Bash(dd:*)",
      "Bash(doas:*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(mkfs:*)",
      "Bash(sudo:*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(/etc/shadow)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/op/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/config)",
      "Read(~/.password-store/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "sandbox": {
    "enabled": false,
    "failIfUnavailable": false,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": [
        "/tmp/"
      ],
      "denyWrite": [
        "/etc",
        "/usr",
        "/nix/store",
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.password-store"
      ],
      "denyRead": [
        "~/"
      ]
    },
    "network": {
      "allowedDomains": [
        "claude.com",
        "*.claude.com",
        "anthropic.com",
        "*.anthropic.com",
        "github.com",
        "*.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "cache.nixos.org",
        "channels.nixos.org",
        "*.nixos.org",
        "*.cachix.org",
        "proxy.golang.org",
        "sum.golang.org",
        "crates.io",
        "static.crates.io",
        "registry-1.docker.io",
        "*.docker.io",
        "ghcr.io",
        "127.0.0.1"
      ]
    }
  },
  "preferredNotifChannel": "ghostty",
  "effortLevel": "medium",
  "defaultMode": "auto",
  "model": "sonnet[1m]"
}
