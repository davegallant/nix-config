{
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6[1m]",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(cat*)",
      "Bash(curl*)",
      "Bash(echo*)",
      "Bash(fd*)",
      "Bash(find*)",
      "Bash(gh issue view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh repo view*)",
      "Bash(gh run view*)",
      "Bash(git *)",
      "Bash(grep*)",
      "Bash(hunk session *)",
      "Bash(jq*)",
      "Bash(just*)",
      "Bash(kubectl api-resources*)",
      "Bash(kubectl api-versions*)",
      "Bash(kubectl cluster-info*)",
      "Bash(kubectl config current-context*)",
      "Bash(kubectl config get-contexts*)",
      "Bash(kubectl config view*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl explain*)",
      "Bash(kubectl get*)",
      "Bash(kubectl logs*)",
      "Bash(kubectl top*)",
      "Bash(kubectl version*)",
      "Bash(ls*)",
      "Bash(make*)",
      "Bash(nix build*)",
      "Bash(nix eval*)",
      "Bash(nix flake*)",
      "Bash(nix fmt*)",
      "Bash(nix search*)",
      "Bash(nixfmt*)",
      "Bash(rg*)",
      "Bash(which*)",
      "WebFetch",
      "mcp__plugin_slack_slack__slack_read_canvas",
      "mcp__plugin_slack_slack__slack_read_channel",
      "mcp__plugin_slack_slack__slack_read_thread",
      "mcp__plugin_slack_slack__slack_read_user_profile",
      "mcp__plugin_slack_slack__slack_search_channels",
      "mcp__plugin_slack_slack__slack_search_public",
      "mcp__plugin_slack_slack__slack_search_public_and_private",
      "mcp__plugin_slack_slack__slack_search_users"
    ],
    "deny": [
      "Bash(dd *)",
      "Bash(doas *)",
      "Bash(git clean*)",
      "Bash(git -C * clean*)",
      "Bash(git push --force*)",
      "Bash(git -C * push --force*)",
      "Bash(git push -f*)",
      "Bash(git -C * push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git -C * reset --hard*)",
      "Bash(kill*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl cordon*)",
      "Bash(kubectl create*)",
      "Bash(kubectl delete*)",
      "Bash(kubectl drain*)",
      "Bash(kubectl edit*)",
      "Bash(kubectl exec*)",
      "Bash(kubectl patch*)",
      "Bash(kubectl replace*)",
      "Bash(kubectl rollout restart*)",
      "Bash(kubectl run*)",
      "Bash(kubectl scale*)",
      "Bash(kubectl set*)",
      "Bash(kubectl taint*)",
      "Bash(mkfs*)",
      "Bash(nix store delete*)",
      "Bash(nix store wipe-cache*)",
      "Bash(pkill*)",
      "Bash(poweroff*)",
      "Bash(reboot*)",
      "Bash(rm -f*)",
      "Bash(rm -rf*)",
      "Bash(shutdown*)",
      "Bash(sudo *)",
      "Read(.env)",
      "Read(./.env.*)",
      "Read(/etc/shadow)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/op/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/config)",
      "Read(~/.password-store/**)",
      "Read(~/.ssh/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/tmp/",
        "~/.gnupg"
      ],
      "denyWrite": [
        "/etc",
        "/usr",
        "/nix/store",
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "~/.password-store"
      ],
      "allowRead": [],
      "denyRead": [
        "~/.aws/sso"
      ]
    },
    "network": {
      "allowedDomains": [
        "claude.com",
        "*.claude.com",
        "anthropic.com",
        "*.anthropic.com",
        "github.com",
        "*.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "cache.nixos.org",
        "channels.nixos.org",
        "*.nixos.org",
        "*.cachix.org",
        "pypi.org",
        "files.pythonhosted.org",
        "registry-1.docker.io",
        "*.docker.io",
        "ghcr.io",
        "127.0.0.1"
      ]
    }
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "preferredNotifChannel": "ghostty",
  "editorMode": "vim",
  "effortLevel": "high",
  "defaultMode": "auto",
  "model": "opus[1m]"
}
