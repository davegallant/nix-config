{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "* 0-4 * * *"
  ],
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "nix": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/obsidian\\.nix$/"
      ],
      "matchStrings": [
        "https://github\\.com/(?<depName>Vinzent03/obsidian-git)/releases/download/(?<currentValue>[\\d\\.]+)/obsidian-git-[\\d\\.]+\\.zip"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/overlays/subtui/default\\.nix$/"
      ],
      "matchStrings": [
        "rev = \"v(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "MattiaPun/SubTUI",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/claude/package\\.nix$/"
      ],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "anthropics/claude-code",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/pi/package\\.nix$/"
      ],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "badlogic/pi-mono",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/hunk/package\\.nix$/"
      ],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "modem-dev/hunk",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/pi\\.nix$/"
      ],
      "matchStrings": [
        "git:github\\.com/(?<depName>mitsuhiko/agent-stuff)@(?<currentDigest>[a-f0-9]{40})"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{depName}}",
      "currentValueTemplate": "main"
    }
  ]
}
