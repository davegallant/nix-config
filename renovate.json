{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "* 0-4 * * *"
  ],
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "groupName": "nix flake inputs",
    },
    {
      "matchManagers": [
        "nix"
      ],
      "matchDepNames": [
        "nixpkgs",
        "nixpkgs-unstable"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/flake\\.nix$/"
      ],
      "matchStrings": [
        "github:NixOS/nixpkgs/(?<currentDigest>[a-f0-9]+)[^\n]*# renovate: currentValue=(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "NixOS/nixpkgs",
      "packageNameTemplate": "https://github.com/NixOS/nixpkgs",
      "datasourceTemplate": "git-refs",
      "versioningTemplate": "git"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/obsidian\\.nix$/"
      ],
      "matchStrings": [
        "https://github\\.com/(?<depName>Vinzent03/obsidian-git)/releases/download/(?<currentValue>[\\d\\.]+)/obsidian-git-[\\d\\.]+\\.zip"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/overlays/subtui/default\\.nix$/"
      ],
      "matchStrings": [
        "rev = \"v(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "MattiaPun/SubTUI",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/claude/package\\.nix$/"
      ],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "anthropics/claude-code",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/opencode/package\\.nix$/"
      ],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "anomalyco/opencode",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
