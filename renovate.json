{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "after 5pm on friday"
  ],
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/anomalyco/opencode"],
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["home/opencode\\.nix"],
      "matchStrings": ["VERSION=\"(?<currentValue>[^\"]+)\""],
      "depNameTemplate": "ghcr.io/anomalyco/opencode",
      "datasourceTemplate": "docker"
    }
  ]
}
