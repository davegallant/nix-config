{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "on the 1st day of the month"
  ],
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "nix": {
    "enabled": false
  },
  "packageRules": [
    {
      "matchManagers": [
        "nix"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/(claude|hunk|pi)/package\\.nix$/"
      ],
      "matchStrings": [
        "version = \"(?<currentValue>[^\"]+)\";\\s*# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)"
      ],
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/pi\\.nix$/"
      ],
      "matchStrings": [
        "git:github\\.com/(?<depName>mitsuhiko/agent-stuff)@(?<currentDigest>[a-f0-9]{40})"
      ],
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/{{depName}}",
      "currentValueTemplate": "main"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/home/lib/skills\\.nix$/"
      ],
      "matchStrings": [
        "rev = \"(?<currentDigest>[a-f0-9]{40})\";"
      ],
      "depNameTemplate": "davegallant/skills",
      "datasourceTemplate": "git-refs",
      "packageNameTemplate": "https://github.com/davegallant/skills",
      "currentValueTemplate": "main"
    }
  ]
}
