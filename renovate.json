{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "schedule": [
    "after 6am before 7am on weekdays"
  ],
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "groupName": "nix flake inputs",
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "matchManagers": ["regex"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["home/obsidian\\.nix$"],
      "matchStrings": [
        "https://github\\.com/(?<depName>Vinzent03/obsidian-git)/releases/download/(?<currentValue>[\\d\\.]+)/obsidian-git-[\\d\\.]+\\.zip"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["overlays/subtui/default\\.nix$"],
      "matchStrings": [
        "rev = \"v(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "MattiaPun/SubTUI",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["home/claude/package\\.nix$"],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "anthropics/claude-code",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "fileMatch": ["home/opencode/package\\.nix$"],
      "matchStrings": [
        "version = \"(?<currentValue>[\\d\\.]+)\";"
      ],
      "depNameTemplate": "anomalyco/opencode",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ]
}
